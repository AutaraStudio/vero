        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              },
              {
                "flag": "min",
                "constraint": 1
              }
            ],
            "level": "error"
          }
        ],
        "description": "Controls the order cards appear (1 = first)",
        "name": "order",
        "type": "number",
        "title": "Display Order"
      },
      {
        "initialValue": false,
        "description": "Shows the \"Most popular\" badge and uses the brand-purple-deep theme",
        "name": "isFeatured",
        "type": "boolean",
        "title": "Featured (Most Popular)"
      },
      {
        "description": "e.g. \"Annual subscription\", \"Single edition\", \"Bespoke\"",
        "name": "tierLabel",
        "type": "string"
      },
      {
        "rows": 2,
        "name": "tagline",
        "type": "text"
      },
      {
        "description": "Formatted price string shown on card, e.g. \"£9,000\"",
        "name": "priceDisplay",
        "type": "string"
      },
      {
        "description": "Raw number for logic/calculations",
        "name": "annualPrice",
        "type": "number",
        "title": "Annual Price (numeric)"
      },
      {
        "description": "e.g. \"Pay monthly or annually\", \"Pay in full\"",
        "name": "paymentOptions",
        "type": "string"
      },
      {
        "description": "e.g. \"Annual\", \"Available to use for 12 months or until credits used\"",
        "name": "duration",
        "type": "string"
      },
      {
        "description": "Leave empty for Bespoke (unlimited)",
        "name": "candidateLimit",
        "type": "number"
      },
      {
        "description": "Leave empty for Bespoke (unlimited)",
        "name": "roleLimit",
        "type": "number"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "ctaLabel",
        "type": "string",
        "title": "CTA Label"
      },
      {
        "options": {
          "list": [
            {
              "title": "Buy (goes to purchase flow)",
              "value": "buy"
            },
            {
              "title": "Contact (goes to contact page)",
              "value": "contact"
            }
          ],
          "layout": "radio"
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "valid",
                "constraint": [
                  "buy",
                  "contact"
                ]
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "ctaType",
        "type": "string",
        "title": "CTA Type"
      },
